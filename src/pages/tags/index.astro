---
import { fetchPosts } from "../../esa-utils/fetch";
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";

const response = await fetchPosts();
const posts = response.posts;

const tags = [...new Set(posts.flatMap((post) => post.wip ? [] : post.tags))];

const tagCounts = tags.map((tag) => ({
  tag,
  count: posts.filter((post) => post.tags.includes(tag) && !post.wip).length,
}));
---

<Layout>
  <div class="card-container">
    <h2 class="heading">タグ一覧</h2>
    {
      tagCounts.map((tagCount) => (
        <Card
          href={`/tags/${tagCount.tag}`}
          title={`${tagCount.tag} (${tagCount.count} 記事)`}
          imgSrc={undefined}
        />
      ))
    }
  </div>
</Layout>

<style>
  .heading {
    font-size: 1.5rem;
    padding-inline: 11px;
    padding-block: 0.1rem;
    border-inline-start: 7px solid var(--theme-color-accent);
    border-block-end: 1px solid var(--border-color);
  }
  .card-container {
    display: flex;
    flex-direction: column;
    margin-inline: auto;
    gap: 0.5rem;
  }
</style>
